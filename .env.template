# Copy to .env and fill in real values before deploying

# WebSocket URL for the frontend to connect to
VITE_WS_URL=ws://localhost:3001

# Cloudflare tunnel token (get from Cloudflare Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# Port the Node server listens on
PORT=3001

# Path where uploaded asset files are stored (absolute, inside the container)
ASSET_STORAGE_PATH=/app/storage/assets

# SQLite database path
DB_PATH=/app/data/layout.db
